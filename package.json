{
  "name": "schemasniff-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build --target bundler --release",
    "build:ts": "tsc",
    "build": "npm run build:wasm && npm run build:ts && node scripts/postbuild.mjs",
    "dev": "cd demo && npm run dev",
    "test:rust": "cargo test",
    "test:clippy": "cargo clippy -- -D warnings",
    "test:audit": "cargo audit && cargo deny check",
    "lint": "eslint src/**/*.ts",
    "test:all": "npm run test:rust && npm run test:clippy && npm run test:audit && npm run lint",
    "prepublish": "npm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "typescript": "^5.0.0"
  }
}
